PROJECT_NAME=IMock
API_V1_STR=/api/v1
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=123
ADMIN_FULL_NAME=IMock

# Images for docker-compose.cloud.yaml.
BACKEND_IMAGE=ghcr.io/<github-owner>/<github-repo>-backend:latest
FRONTEND_IMAGE=ghcr.io/<github-owner>/<github-repo>-frontend:latest

# Public frontend origins. API requests go through frontend nginx at /api/v1.
# Example for a VM:
# BACKEND_CORS_ORIGINS=http://<vm-public-ip>,http://<your-domain>
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:80
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:80

# Optional host ports.
FRONTEND_PORT=80

# SQLite is stored in the Docker volume configured by docker-compose-prod.yaml.
# The compose file overrides DATABASE_URL to sqlite+aiosqlite:///./data/imock.db.

LLM_MODE=yandex_agents
YANDEX_FOLDER_ID=b1...
YANDEX_API_KEY=AQVN...
YANDEX_AI_STUDIO_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_REVIEW_AGENT_MODEL=gpt://b1.../yandexgpt-5.1/latest
YANDEX_INTERVIEW_AGENT_MODEL=gpt://b1gk./yandexgpt-5.1/latest
YANDEX_QUESTION_AGENT_MODEL=gpt://b1gk.../yandexgpt-5.1/latest
YANDEX_AGENTS_TIMEOUT_SECONDS=60
YANDEX_AGENT_STORE_RESPONSES=false
